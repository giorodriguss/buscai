# ============================================================
# Supabase
# Painel: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
# ============================================================
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ============================================================
# JWT
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# ============================================================
# Servidor (opcional — padrão: 3000)
# ============================================================
PORT=3000
